<?xml version="1.0" encoding="UTF-8"?>
<lint>
    <!-- 禁用可能导致内部异常的规则 -->
    <issue id="AppLinksAutoVerify" severity="ignore" />
    <issue id="ConvertToWebp" severity="ignore" />
    <issue id="MissingApplicationIcon" severity="ignore" />
    <issue id="GoogleAppIndexingWarning" severity="ignore" />
    
    <!-- WebView 相关 -->
    <issue id="SetJavaScriptEnabled" severity="ignore" />
    <issue id="AddJavascriptInterface" severity="ignore" />
    
    <!-- 通用容忍设置 -->
    <issue id="AllowBackup" severity="warning" />
    <issue id="Typos" severity="ignore" />
    
    <!-- Kotlin 序列化相关 -->
    <issue id="UnusedResources" severity="warning" />
    
    <!-- 忽略 Lint 自身的内部错误（避免构建中断）-->
    <issue id="UnknownNullness" severity="ignore" />
    <issue id="DefaultLocale" severity="ignore" />
    <issue id="StaticFieldLeak" severity="warning" />
</lint>