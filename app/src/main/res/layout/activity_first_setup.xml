<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="48sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="欢迎使用学校浏览器"
            android:textSize="22sp"
            android:textColor="@color/url_bar_text"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="首次使用请设置管理密码"
            android:textSize="14sp"
            android:textColor="@color/blocked_page_text"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- 密码设置 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_password_label"
            android:textSize="15sp"
            android:textColor="@color/url_bar_text"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_setup_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/password_hint"
            android:inputType="textPassword"
            android:maxLines="1"
            android:singleLine="true"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/et_setup_confirm_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/confirm_password_hint"
            android:inputType="textPassword"
            android:maxLines="1"
            android:singleLine="true"
            android:layout_marginBottom="16dp" />

        <!-- 恢复种子显示区域（设置密码后显示） -->
        <TextView
            android:id="@+id/tv_seed_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_seed_label"
            android:textSize="15sp"
            android:textColor="@color/url_bar_text"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_seed_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_seed_hint"
            android:textSize="12sp"
            android:textColor="#E53935"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tv_seed_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/primary_blue"
            android:gravity="center"
            android:fontFamily="monospace"
            android:letterSpacing="0.08"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_complete_setup"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/setup_complete"
            android:layout_marginTop="32dp" />
    </LinearLayout>
</ScrollView>